{
  "manifest_version": 3,
  "name": "Nudge Tab Monitor",
  "version": "1.0.0",
  "description": "Reports active tab info to Nudge for browser-based time tracking.",
  "permissions": ["tabs", "activeTab", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nudge Tab Monitor"
  }
}
